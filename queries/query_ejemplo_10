# Query con mucho flush para probar flush_archivo() en storage

CREATE SO:PROCESOS_BASE
TRUNCATE SO:PROCESOS_BASE 512
WRITE SO:PROCESOS_BASE 0 Proceso_1:Estado_Listo_Prioridad_3
WRITE SO:PROCESOS_BASE 128 Proceso_2:Estado_Ejecutando_Prioridad_1
WRITE SO:PROCESOS_BASE 256 Proceso_3:Estado_Espera_Prioridad_2
WRITE SO:PROCESOS_BASE 384 Proceso_4:Estado_Listo_Prioridad_4
FLUSH SO:PROCESOS_BASE

CREATE SO:MEMORIA_BASE
TRUNCATE SO:MEMORIA_BASE 384
WRITE SO:MEMORIA_BASE 0 Marco_0:Proceso_1_Pagina_0
WRITE SO:MEMORIA_BASE 128 Marco_1:Proceso_2_Pagina_0
WRITE SO:MEMORIA_BASE 256 Marco_2:Proceso_3_Pagina_0
FLUSH SO:MEMORIA_BASE

TAG SO:PROCESOS_BASE SO:PROCESOS_V1
WRITE SO:PROCESOS_V1 0 Proceso_1:Estado_Ejecutando_Prioridad_3
WRITE SO:PROCESOS_V1 128 Proceso_2:Estado_Listo_Prioridad_1
WRITE SO:PROCESOS_V1 256 Proceso_5:Estado_Listo_Prioridad_2
FLUSH SO:PROCESOS_V1

CREATE SO:ARCHIVOS_SISTEMA
TRUNCATE SO:ARCHIVOS_SISTEMA 256
WRITE SO:ARCHIVOS_SISTEMA 0 config_sys:kernel_version_5_4
WRITE SO:ARCHIVOS_SISTEMA 128 logs_sys:startup_completed
FLUSH SO:ARCHIVOS_SISTEMA

TAG SO:MEMORIA_BASE SO:MEMORIA_V1
WRITE SO:MEMORIA_V1 0 Marco_0:Proceso_1_Pagina_0
WRITE SO:MEMORIA_V1 128 Marco_3:Proceso_5_Pagina_0
WRITE SO:MEMORIA_V1 256 Marco_4:Libre
FLUSH SO:MEMORIA_V1

CREATE SO:DISPOSITIVOS
TRUNCATE SO:DISPOSITIVOS 128
WRITE SO:DISPOSITIVOS 0 Dispositivo_1:Estado_Activo
FLUSH SO:DISPOSITIVOS

COMMIT SO:PROCESOS_V1
COMMIT SO:MEMORIA_V1
COMMIT SO:ARCHIVOS_SISTEMA
COMMIT SO:DISPOSITIVOS

READ SO:PROCESOS_BASE 0 30
READ SO:PROCESOS_V1 0 30
READ SO:MEMORIA_BASE 0 25
READ SO:MEMORIA_V1 0 25
READ SO:ARCHIVOS_SISTEMA 0 20
READ SO:DISPOSITIVOS 0 15

END