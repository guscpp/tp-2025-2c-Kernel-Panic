#!/bin/bash

# Script para compilar e iniciar múltiples instancias de query con logs de Valgrind robustos
if [ $# -ne 1 ]; then
    echo "Uso: $0 <cantidad_instancias>"
    exit 1
fi

CANTIDAD=$1
LOG_DIR="valgrind_logs_$(date +%Y%m%d_%H%M%S)"
mkdir -p "$LOG_DIR"

echo "Compilando query_control..."
make 

if [ $? -ne 0 ]; then
    echo "Error en la compilación del query_control"
    exit 1
fi

echo "Iniciando $CANTIDAD instancias de query con monitoreo de Valgrind..."
echo "Logs se guardarán en: $LOG_DIR"
echo ""

# Función de limpieza al recibir Ctrl+C
cleanup() {
    echo -e "\n\n[$(date +'%T')] Interrupción detectada (Ctrl+C). Finalizando procesos limpiamente..."
    kill $PIDS 2>/dev/null
    wait $PIDS 2>/dev/null
    echo "[$(date +'%T')] Procesos finalizados. ¡Los logs de Valgrind YA FUERON ESCRITOS!"
    exit 130
}

# Configurar trap para SIGINT (Ctrl+C)
trap cleanup SIGINT

ejecutar_instancia() {
    local idx=$1
    local prioridad=$2
    local log_valgrind="$LOG_DIR/valgrind_query_${idx}.log"
    
    echo "[$(date +'%T')] Iniciando query $idx (prioridad $prioridad)"
    echo "  - Log de Valgrind: $log_valgrind"
    
    # Comando de Valgrind simplificado y robusto
    valgrind \
        --tool=memcheck \
        --leak-check=full \
        --show-leak-kinds=all \
        --track-origins=yes \
        --verbose \
        --log-file="$log_valgrind" \
        --child-silent-after-fork=yes \
        ./bin/query_control ./query_control.config "query_ejemplo_$idx" "$prioridad"
}

if [ $CANTIDAD -eq 1 ]; then
    echo "Ejecutando instancia única en PRIMER PLANO (Ctrl+C finalizará limpiamente):"
    ejecutar_instancia 0 0
else
    PIDS=""
    for ((i=0; i<CANTIDAD; i++)); do
        ejecutar_instancia $i $i &
        PID=$!
        PIDS="$PIDS $PID"
        echo "  [Query $i] PID: $PID"
        sleep 0.5
    done

    echo -e "\n[$(date +'%T')] $CANTIDAD instancias ejecutándose en background"
    echo "Presiona Ctrl+C en CUALQUIER MOMENTO para finalizar TODOS los procesos limpiamente"
    echo "y generar los logs completos de Valgrind."
    echo ""
    echo "Monitoreo en tiempo real de logs:"
    echo "  tail -f $LOG_DIR/*.log"
    echo ""
    
    # Esperar a que terminen todos los procesos (o Ctrl+C)
    wait $PIDS
    echo -e "\n[$(date +'%T')] Todas las instancias finalizaron normalmente."
fi

echo -e "\n[$(date +'%T')] ¡Listo! Todos los logs de Valgrind están en:"
echo "  $LOG_DIR/"
echo ""
echo "Para analizar leaks:"
echo "  grep -i 'leak summary' $LOG_DIR/*.log"
echo ""