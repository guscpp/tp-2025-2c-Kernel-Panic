#!/bin/bash

# Script para compilar e iniciar múltiples instancias de query
if [ $# -ne 1 ]; then
    echo "Uso: ./query <cantidad_instancias>"
    exit 1
fi

CANTIDAD=$1

echo "Compilando query_control..."
make 

if [ $? -ne 0 ]; then
    echo "Error en la compilación del query_control"
    exit 1
fi

echo "Iniciando $CANTIDAD instancias de query..."
echo ""

PIDS=""
if [ $CANTIDAD -eq 1 ]; then
    echo "Iniciando query 0 con prioridad 0 (ejecución en primer plano)"
    
    # Limpiar log anterior
    rm -f valgrind_query.log
    
    # Versión más simple y confiable de valgrind
    valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes --log-file=valgrind_query.log ./bin/query_control ./query_control.config "query_ejemplo_0" 0
    
    # Mostrar resumen del log
    echo ""
    echo "=== RESUMEN VALGRIND ==="
    tail -20 valgrind_query.log
    echo ""
    echo "Log completo en: valgrind_query.log"
    
else
    for ((i=0; i<$CANTIDAD; i++)); do
        echo "Iniciando query $i con prioridad $i"
        ./bin/query_control ./query_control.config "query_ejemplo_$i" $i &
        PID=$!
        PIDS="$PIDS $PID"
        echo "  PID: $PID"
        sleep 1
    done

    echo "Para terminar los procesos (si no crashearon primero) se ejecuta:"
    echo "  kill $PIDS"
    echo ""
    echo "Para verificar que están ejecutándose:"
    echo "  ps -p $PIDS -o pid,cmd"
fi