#!/bin/bash
# Script: test_5-prueba_estabilidad_general.sh
# Descripción: Prueba Estabilidad General - Múltiples workers y queries con cambios dinámicos
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }

wait_with_message() {
    local seconds=$1
    local message=$2
    print_info "$message - Esperando $seconds segundos..."
    sleep $seconds
}

is_process_running() {
    pgrep -f "$1" > /dev/null 2>&1
}

kill_tp_processes() {
    print_info "Finalizando procesos del TP..."
    pkill -f "./bin/storage" 2>/dev/null
    pkill -f "./bin/master" 2>/dev/null
    pkill -f "./bin/worker" 2>/dev/null
    pkill -f "./bin/query_control" 2>/dev/null
    sleep 2
}

safe_cleanup() {
    echo
    print_info "Ctrl+C recibido. Limpiando..."
    kill_tp_processes
    print_info "Limpieza completada. Saliendo..."
    exit 0
}

trap safe_cleanup INT TERM

BASE_DIR="$(pwd)"
QUERIES_DIR="$BASE_DIR/queries"
TEST_NAME="test_5-prueba_estabilidad_general"
LOG_DIR="$BASE_DIR/logs_de_tests/$TEST_NAME"

mkdir -p "$LOG_DIR"

# Agregar separador en logs
SEPARATOR="==============================================================================="
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
LOG_HEADER="
$SEPARATOR
===  NUEVA EJECUCION: $TIMESTAMP                                   ===
$SEPARATOR"

for log in storage.log master.log worker{1..6}.log query_batch.log; do
    echo -e "$LOG_HEADER" >> "$LOG_DIR/$log"
done

print_info "Iniciando Prueba Estabilidad General - Workers dinámicos y múltiples queries"
print_info "Directorio base: $BASE_DIR"

# Verificar binarios
bins=(
    "$BASE_DIR/storage/bin/storage"
    "$BASE_DIR/master/bin/master"
    "$BASE_DIR/worker/bin/worker"
    "$BASE_DIR/query_control/bin/query_control"
)
for bin in "${bins[@]}"; do
    [ -f "$bin" ] || { print_error "Binario no encontrado: $bin"; exit 1; }
done
print_info "Todos los binarios encontrados"

# === CONFIGURAR .config LOCALES ===
print_info "Configurando master/master.config para PRIORIDADES..."
cat > "$BASE_DIR/master/master.config" << EOF
PUERTO_ESCUCHA=9001
ALGORITMO_PLANIFICACION=PRIORIDADES
TIEMPO_AGING=250
LOG_LEVEL=INFO
EOF

print_info "Configurando storage/storage.config (FRESH_START=FALSE)..."
cat > "$BASE_DIR/storage/storage.config" << EOF
PUERTO_ESCUCHA=9002
FRESH_START=FALSE
PUNTO_MONTAJE=$BASE_DIR/storage
RETARDO_OPERACION=100
RETARDO_ACCESO_BLOQUE=100
LOG_LEVEL=DEBUG
EOF

# Configurar superblock.config
print_info "Configurando superblock.config (FS_SIZE=4096, BLOCK_SIZE=16)..."
cat > "$BASE_DIR/storage/superblock.config" << EOF
BLOCK_SIZE=16
FS_SIZE=4096
EOF

# Configurar workers con diferentes configuraciones
print_info "Configurando workers con diferentes tamaños de memoria y algoritmos..."

# Worker 1
cat > "$BASE_DIR/worker/worker1.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=128
RETARDO_MEMORIA=100
ALGORITMO_REEMPLAZO=LRU
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Worker 2
cat > "$BASE_DIR/worker/worker2.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=256
RETARDO_MEMORIA=50
ALGORITMO_REEMPLAZO=CLOCK-M
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Worker 3
cat > "$BASE_DIR/worker/worker3.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=64
RETARDO_MEMORIA=150
ALGORITMO_REEMPLAZO=CLOCK-M
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Worker 4
cat > "$BASE_DIR/worker/worker4.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=96
RETARDO_MEMORIA=125
ALGORITMO_REEMPLAZO=LRU
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Worker 5
cat > "$BASE_DIR/worker/worker5.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=160
RETARDO_MEMORIA=75
ALGORITMO_REEMPLAZO=LRU
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Worker 6
cat > "$BASE_DIR/worker/worker6.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
IP_STORAGE=127.0.0.1
PUERTO_STORAGE=9002
TAM_MEMORIA=192
RETARDO_MEMORIA=175
ALGORITMO_REEMPLAZO=CLOCK-M
PATH_QUERIES=$QUERIES_DIR
LOG_LEVEL=DEBUG
EOF

# Configurar query_control.config
cat > "$BASE_DIR/query_control/query_control.config" << EOF
IP_MASTER=127.0.0.1
PUERTO_MASTER=9001
LOG_LEVEL=DEBUG
EOF
print_info "Todos los workers configurados con diferentes características"

# === INICIAR MÓDULOS BASE ===
declare -a PIDS=()
add_pid() { PIDS+=($1); }

# Storage
print_info "Iniciando Storage desde su carpeta..."
cd "$BASE_DIR/storage"
./bin/storage storage.config >> "$LOG_DIR/storage.log" 2>&1 &
STORAGE_PID=$!
add_pid $STORAGE_PID
wait_with_message 5 "Esperando que Storage esté listo"
if is_process_running "storage"; then
    print_info "Storage iniciado (PID: $STORAGE_PID)"
else
    print_error "Error al iniciar Storage. Revisar $LOG_DIR/storage.log"
    exit 1
fi

# Master
print_info "Iniciando Master desde su carpeta..."
cd "$BASE_DIR/master"
./bin/master master.config >> "$LOG_DIR/master.log" 2>&1 &
MASTER_PID=$!
add_pid $MASTER_PID
wait_with_message 5 "Esperando que Master esté listo"
if is_process_running "master"; then
    print_info "Master iniciado (PID: $MASTER_PID)"
else
    print_error "Error al iniciar Master. Revisar $LOG_DIR/master.log"
    exit 1
fi

# === FASE 1: INICIAR WORKERS 1 Y 2 ===
print_info "=== FASE 1: Iniciando Workers 1 y 2 ==="
cd "$BASE_DIR/worker"

print_info "Iniciando Worker 1 (128MB, LRU, 100ms)..."
./bin/worker worker1.config 1 >> "$LOG_DIR/worker1.log" 2>&1 &
WORKER1_PID=$!
add_pid $WORKER1_PID

print_info "Iniciando Worker 2 (256MB, CLOCK-M, 50ms)..."
./bin/worker worker2.config 2 >> "$LOG_DIR/worker2.log" 2>&1 &
WORKER2_PID=$!
add_pid $WORKER2_PID

wait_with_message 5 "Esperando que Workers 1 y 2 estén listos"

# === EJECUTAR 25 INSTANCIAS DE CADA QUERY AGING ===
print_info "=== Ejecutando 25 instancias de cada Query Aging en segundo plano ==="
cd "$BASE_DIR/query_control"

print_info "Lanzando 25 instancias de cada query Aging con prioridad 20..."
for i in {1..25}; do
    ./bin/query_control query_control.config "$QUERIES_DIR/AGING_1" 20 >> "$LOG_DIR/query_batch.log" 2>&1 &
    add_pid $!
    ./bin/query_control query_control.config "$QUERIES_DIR/AGING_2" 20 >> "$LOG_DIR/query_batch.log" 2>&1 &
    add_pid $!
    ./bin/query_control query_control.config "$QUERIES_DIR/AGING_3" 20 >> "$LOG_DIR/query_batch.log" 2>&1 &
    add_pid $!
    ./bin/query_control query_control.config "$QUERIES_DIR/AGING_4" 20 >> "$LOG_DIR/query_batch.log" 2>&1 &
    add_pid $!
done

print_info "Todas las queries lanzadas (100 total) - Esperando 30-60 segundos..."
wait_with_message 40 "Espera inicial con Workers 1 y 2"

# === FASE 2: INICIAR WORKERS 3 Y 4 ===
print_info "=== FASE 2: Iniciando Workers 3 y 4 ==="
cd "$BASE_DIR/worker"

print_info "Iniciando Worker 3 (64MB, CLOCK-M, 150ms)..."
./bin/worker worker3.config 3 >> "$LOG_DIR/worker3.log" 2>&1 &
WORKER3_PID=$!
add_pid $WORKER3_PID

print_info "Iniciando Worker 4 (96MB, LRU, 125ms)..."
./bin/worker worker4.config 4 >> "$LOG_DIR/worker4.log" 2>&1 &
WORKER4_PID=$!
add_pid $WORKER4_PID

print_info "Workers 3 y 4 iniciados - Esperando 30-60 segundos..."
wait_with_message 45 "Espera con Workers 1-4 activos"

# === FASE 3: FINALIZAR WORKERS 1 Y 2 ===
print_info "=== FASE 3: Finalizando Workers 1 y 2 ==="
print_info "Finalizando Worker 1 (PID: $WORKER1_PID)..."
kill $WORKER1_PID 2>/dev/null
print_info "Finalizando Worker 2 (PID: $WORKER2_PID)..."
kill $WORKER2_PID 2>/dev/null

wait_with_message 5 "Esperando que Workers 1 y 2 finalicen"
print_info "Workers 1 y 2 finalizados - Esperando 30-60 segundos..."
wait_with_message 45 "Espera con Workers 3-4 activos"

# === FASE 4: INICIAR WORKERS 5 Y 6 ===
print_info "=== FASE 4: Iniciando Workers 5 y 6 ==="
cd "$BASE_DIR/worker"

print_info "Iniciando Worker 5 (160MB, LRU, 75ms)..."
./bin/worker worker5.config 5 >> "$LOG_DIR/worker5.log" 2>&1 &
WORKER5_PID=$!
add_pid $WORKER5_PID

print_info "Iniciando Worker 6 (192MB, CLOCK-M, 175ms)..."
./bin/worker worker6.config 6 >> "$LOG_DIR/worker6.log" 2>&1 &
WORKER6_PID=$!
add_pid $WORKER6_PID

print_info "Workers 5 y 6 iniciados - Todos los workers 3-6 activos"

# === MONITOREO FINAL ===
print_info "=== MONITOREO FINAL: Esperando finalización de todas las queries ==="
print_info "Monitoreando ejecución... Logs en: $LOG_DIR/"

TOTAL_QUERIES=100
for i in {1..60}; do
    sleep 10
    q=$(pgrep -f "query_control" | wc -l)
    queries_completadas=$((TOTAL_QUERIES - q))
    print_info "Queries en ejecución: $q - Completadas: $queries_completadas/$TOTAL_QUERIES"
    
    # Mostrar estado de workers cada 30 segundos
    if [ $((i % 3)) -eq 0 ]; then
        workers_activos=$(pgrep -f "worker" | wc -l)
        print_info "Workers activos: $workers_activos/4 (3-6)"
    fi
    
    [ $q -eq 0 ] && { print_info "Todas las queries finalizaron"; break; }
    
    if [ $i -eq 30 ]; then
        print_warning "Las queries están tomando más tiempo del esperado..."
    fi
done

print_info "=== PRUEBA ESTABILIDAD GENERAL COMPLETADA ==="
print_info "Resultados esperados:"
print_info "✓ No se observan esperas activas"
print_info "✓ No hay memory leaks" 
print_info "✓ Sistema no finalizó de manera abrupta"
print_info "✓ Manejo correcto de conexiones/desconexiones dinámicas de workers"
print_info "✓ Las queries completaron exitosamente a pesar de los cambios"
print_info ""
print_info "Logs disponibles en: $LOG_DIR/"
print_info "Presiona Ctrl+C para finalizar todos los módulos."
while true; do sleep 10; done